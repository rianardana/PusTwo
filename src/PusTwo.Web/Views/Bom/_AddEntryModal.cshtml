<div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-gradient-to-r from-blue-50 to-indigo-50 rounded-t-xl">
    <h3 class="font-bold text-lg text-gray-800">Add Down Time</h3>
    <button type="button" onclick="closeModal()" class="text-gray-400 hover:text-gray-600 hover:bg-gray-200 w-8 h-8 rounded-full transition-all duration-150 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
</div>

<div class="p-6 space-y-4">
    <div>
        <label class="block text-sm font-semibold mb-2 text-gray-700">Group Code <span class="text-red-500">*</span></label>
        <select id="groupCodeSelect" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
            <option value="">-- Select Group --</option>
        </select>
    </div>

    <div>
        <label class="block text-sm font-semibold mb-2 text-gray-700">Downtime Code <span class="text-red-500">*</span></label>
        <select id="codeSelect" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white" disabled>
            <option value="">-- Select Group First --</option>
        </select>
    </div>

    <div>
        <label class="block text-sm font-semibold mb-2 text-gray-700">Downtime (Minutes) <span class="text-red-500">*</span></label>
        <input type="number" id="downtimeMinutesInput" min="1" placeholder="Enter minutes" 
               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" />
    </div>

    <div>
        <label class="block text-sm font-semibold mb-2 text-gray-700">Remark</label>
        <textarea id="remarkInput" rows="3" maxlength="255" placeholder="Optional remark..." 
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all resize-none"></textarea>
        <p class="text-xs text-gray-500 mt-1">Max 255 characters</p>
    </div>
</div>

<div class="px-6 py-4 border-t border-gray-200 flex gap-3 bg-gray-50 rounded-b-xl">
    <button type="button" onclick="addDowntimeEntry()" 
            class="flex-1 py-2.5 rounded-lg font-semibold text-sm text-white transition-all duration-200 bg-blue-600 hover:bg-blue-700 hover:shadow-lg transform hover:-translate-y-0.5">
        Add Entry
    </button>
    <button type="button" onclick="closeModal()" 
            class="flex-1 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200 border-2 border-gray-300 text-gray-700 hover:bg-gray-100 hover:border-gray-400">
        Cancel
    </button>
</div>
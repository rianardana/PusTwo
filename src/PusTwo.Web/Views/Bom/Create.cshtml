@model PusTwo.Web.ViewModels.BomViewModel
@{
    ViewData["Title"] = "BOM Operation Lookup";
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-blue-50 py-8 px-4">
    <div class="max-w-7xl mx-auto">
        
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">BOM Operation Lookup</h1>
            <p class="text-gray-600 mt-2">Masukkan Job Number untuk mengambil data WorkCentre dari Syspro (Route 0)</p>
        </div>

        <!-- Dynamic Status Banner -->
        <div id="statusBanner" class="hidden mb-6 p-4 rounded-xl text-sm font-medium border shadow-sm transition-all duration-200"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            
            <!-- Left: Input Panel -->
            <div class="lg:col-span-4">
                <div class="bg-white rounded-xl shadow-lg border border-gray-200 p-6 sticky top-6">
                    <h2 class="text-lg font-semibold text-gray-800 mb-4">Job Information</h2>
                    
                    <!-- Job Number Input -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Job Number <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <input type="text" id="jobInput" 
                                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-base"
                                   placeholder="Contoh: 60438146" 
                                   autocomplete="off" />
                            <div id="loader" class="absolute right-3 top-3 hidden">
                                <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-2">💡 Data akan muncul otomatis 0.4 detik setelah berhenti mengetik</p>
                    </div>

                    <!-- StockCode Display -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Stock Code</label>
                        <div id="stockCodeDisplay" class="px-4 py-2.5 bg-gray-100 border border-gray-300 rounded-lg text-sm font-mono text-gray-700 font-semibold">
                            <span class="text-gray-400 italic">-</span>
                        </div>
                    </div>

                    <hr class="my-6 border-gray-200" />

                    <!-- Quick Stats -->
                    <div class="space-y-3">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-gray-600">Total Operations:</span>
                            <span id="totalOps" class="font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded">0</span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-gray-600">WorkCentre:</span>
                            <span id="totalWC" class="font-bold text-green-600 bg-green-50 px-2 py-1 rounded">-</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Results Panel -->
            <div class="lg:col-span-8 space-y-4">
                
                <!-- Table View -->
                <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b bg-gradient-to-r from-gray-50 to-white flex justify-between items-center">
                        <div>
                            <h2 class="font-bold text-gray-800 text-lg">WorkCentre Results (Route 0)</h2>
                            <p class="text-xs text-gray-500 mt-1">Data diurutkan berdasarkan Operation Sequence</p>
                        </div>
                        <span id="recordCount" class="text-sm font-bold bg-gray-200 text-gray-700 px-3 py-1.5 rounded-full">0 items</span>
                    </div>
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left">
                            <thead class="bg-gray-100 text-gray-700 uppercase text-xs tracking-wider font-semibold">
                                <tr>
                                    <th class="px-6 py-3 border-b">Operation</th>
                                    <th class="px-6 py-3 border-b">WorkCentre</th>
                                    <th class="px-6 py-3 border-b">Route</th>
                                    <th class="px-6 py-3 border-b">StockCode</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody" class="divide-y divide-gray-100">
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">
                                        <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                        </svg>
                                        Masukkan Job Number untuk melihat data WorkCentre
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Raw JSON Debug Panel -->
                <div class="bg-gray-900 rounded-xl shadow-lg border border-gray-700 overflow-hidden">
                    <div class="px-4 py-3 bg-gray-800 border-b border-gray-700 flex justify-between items-center">
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-mono text-green-400">📦</span>
                            <span class="text-xs font-semibold text-gray-300">RAW JSON RESPONSE</span>
                        </div>
                        <button id="toggleJson" class="text-xs text-gray-400 hover:text-white transition bg-gray-700 hover:bg-gray-600 px-3 py-1.5 rounded-lg font-medium">
                            Show / Hide
                        </button>
                    </div>
                    <pre id="jsonOutput" class="hidden p-4 text-xs font-mono text-gray-300 overflow-x-auto max-h-96 whitespace-pre-wrap break-words bg-gray-950"></pre>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const jobInput = document.getElementById('jobInput');
    const loader = document.getElementById('loader');
    const statusBanner = document.getElementById('statusBanner');
    const tableBody = document.getElementById('tableBody');
    const recordCount = document.getElementById('recordCount');
    const stockCodeDisplay = document.getElementById('stockCodeDisplay');
    const jsonOutput = document.getElementById('jsonOutput');
    const toggleJson = document.getElementById('toggleJson');
    const totalOps = document.getElementById('totalOps');
    const totalWC = document.getElementById('totalWC');

    let debounceTimer;

    // Toggle JSON visibility
    toggleJson.addEventListener('click', () => jsonOutput.classList.toggle('hidden'));

    // Input handler with debounce
    jobInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const val = jobInput.value.trim();
        
        if (!val) {
            resetUI();
            return;
        }

        // Show searching state
        setStatus('searching', `🔍 Mencari data untuk Job: <b>${escapeHtml(val)}</b>...`);
        loader.classList.remove('hidden');
        tableBody.innerHTML = '<tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">Mengambil data dari Syspro...</td></tr>';
        jsonOutput.textContent = '';

        // Debounce 400ms
        debounceTimer = setTimeout(() => fetchData(val), 400);
    });

    // Enter key trigger
    jobInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            clearTimeout(debounceTimer);
            fetchData(jobInput.value.trim());
        }
    });

    async function fetchData(job) {
        if (!job) return;
        
        try {
            const res = await fetch(`/Bom/GetWorkCentresByJob?jobNumber=${encodeURIComponent(job)}`);
            const json = await res.json();
            
            loader.classList.add('hidden');
            jsonOutput.textContent = JSON.stringify(json, null, 2);

            if (json.success && json.data?.length > 0) {
                // Update StockCode display
                const sc = json.stockCode || json.data[0]?.stockCode || 'N/A';
                stockCodeDisplay.innerHTML = `<span class="font-mono text-blue-700">${escapeHtml(sc)}</span>`;
                
                // Update stats
                totalOps.textContent = json.data.length;
                const uniqueWC = [...new Set(json.data.map(item => item.workCentre))].length;
                totalWC.textContent = uniqueWC;
                
                setStatus('success', `✅ Berhasil! Ditemukan <b>${json.data.length}</b> WorkCentre(s) untuk StockCode: <b class="font-mono">${escapeHtml(sc)}</b>`);
                renderTable(json.data);
                recordCount.textContent = `${json.data.length} items`;
            } else {
                setStatus('warning', `⚠️ ${json.message || 'Data tidak ditemukan di Syspro atau Route 0 kosong.'}`);
                stockCodeDisplay.innerHTML = '<span class="text-gray-400 italic">Not Found</span>';
                clearTable();
                recordCount.textContent = '0 items';
                totalOps.textContent = '0';
                totalWC.textContent = '-';
            }
        } catch (err) {
            loader.classList.add('hidden');
            setStatus('error', '❌ Gagal menghubungi server. Cek koneksi network atau console browser.');
            console.error('Fetch Error:', err);
            jsonOutput.textContent = JSON.stringify({ error: err.message, stack: err.stack }, null, 2);
            stockCodeDisplay.innerHTML = '<span class="text-red-500">Error</span>';
            clearTable();
        }
    }

    function renderTable(data) {
        tableBody.innerHTML = data.map((item, i) => `
            <tr class="${i % 2 === 0 ? 'bg-white hover:bg-blue-50' : 'bg-gray-50 hover:bg-gray-100'} transition-colors">
                <td class="px-6 py-4 font-mono font-semibold text-gray-900">${item.operation}</td>
                <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-semibold bg-blue-100 text-blue-800 border border-blue-200">
                        ${escapeHtml(item.workCentre)}
                    </span>
                </td>
                <td class="px-6 py-4">
                    <span class="px-2.5 py-1 text-xs font-bold rounded-full bg-green-100 text-green-800 border border-green-200">
                        ${escapeHtml(item.route)}
                    </span>
                </td>
                <td class="px-6 py-4 font-mono text-gray-600 text-xs">${escapeHtml(item.stockCode)}</td>
            </tr>
        `).join('');
    }

    function clearTable() {
        tableBody.innerHTML = `
            <tr>
                <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                    <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Tidak ada data yang cocok
                </td>
            </tr>`;
    }

    function resetUI() {
        loader.classList.add('hidden');
        statusBanner.classList.add('hidden');
        stockCodeDisplay.innerHTML = '<span class="text-gray-400 italic">-</span>';
        clearTable();
        recordCount.textContent = '0 items';
        totalOps.textContent = '0';
        totalWC.textContent = '-';
        jsonOutput.textContent = '';
    }

    function setStatus(type, msg) {
        const classes = {
            searching: 'bg-blue-50 text-blue-800 border-blue-200',
            success: 'bg-green-50 text-green-800 border-green-200',
            warning: 'bg-yellow-50 text-yellow-800 border-yellow-200',
            error: 'bg-red-50 text-red-800 border-red-200'
        };
        statusBanner.className = `mb-6 p-4 rounded-xl text-sm font-medium border shadow-sm ${classes[type]}`;
        statusBanner.innerHTML = msg;
        statusBanner.classList.remove('hidden');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
});
</script>
}